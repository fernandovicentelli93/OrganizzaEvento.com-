# Prisma usa PostgreSQL. In locale puoi usare un database Postgres locale
# oppure una stringa di connessione Postgres fornita da Netlify/hosting.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/organizzaevento?schema=public"

ADMIN_SECRET="scegli-una-password-admin-lunga"
ADMIN_EMAIL="supportoforumevento@gmail.com"
ACCOUNT_SESSION_SECRET="scegli-un-segreto-lungo-per-sessioni-account"
CAPTCHA_SECRET="scegli-un-segreto-lungo-per-i-controlli-antispam"
NEXT_PUBLIC_SITE_URL="https://organizzaevento.com"
SUPPORT_EMAIL="supportoforumevento@gmail.com"
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-M2BH2WMNV6"

# Accesso con Google. Il secret va impostato solo nelle variabili ambiente,
# mai nel codice e mai in file tracciati da Git.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="https://organizzaevento.com/api/auth/google/callback"
GOOGLE_OAUTH_STATE_SECRET="scegli-un-segreto-lungo-per-oauth-google"

# Opzionale: abilita notifiche email automatiche verso SUPPORT_EMAIL.
# Scegli uno dei due metodi:
RESEND_API_KEY=""
RESEND_FROM_EMAIL="OrganizzaEvento <notifiche@organizzaevento.com>"
NOTIFICATION_WEBHOOK_URL=""

# Tracciamento chiamate fornitori con Twilio.
# I numeri reali dei fornitori non vanno nel database: usa una mappa server-side
# supplierId -> numero E.164, ad esempio {"abc123":"+393331234567"}.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_VERIFY_SERVICE_SID=""
# Alias supportato se preferisci il nome Twilio standard:
# VERIFY_SERVICE_SID=""
TWILIO_FROM_NUMBER=""
TWILIO_SUPPLIER_PHONE_MAP="{}"
TWILIO_VALIDATE_SIGNATURES="true"
TWILIO_CLICK_TO_CALL_ENABLED="false"
